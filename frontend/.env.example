# Backend API URL — depends on how you deploy:
#
# Netlify deploy (netlify.toml proxies /api, /auth, /minio → VM):
#   leave empty or don't set — all API calls go to same origin
#   VITE_API_BASE_URL=
#
# VM static serve (frontend served from VM alongside backend):
#   VITE_API_BASE_URL=http://e1.chiasegpu.vn:39225
#
# Local dev (vite proxy auto-handles /api and /auth → localhost:8081):
#   leave empty
VITE_API_BASE_URL=

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=

# Enable API debug logging in browser console (true/false)
VITE_API_DEBUG=false
