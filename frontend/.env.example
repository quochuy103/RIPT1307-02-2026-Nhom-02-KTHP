# Backend API URL — change this to match your deployed backend
# Dev (local):    http://localhost:8081 (vite proxy auto-handles this)
# VM deploy:      http://e1.chiasegpu.vn:25232
# Docker + nginx: leave empty (nginx proxies /api and /auth to backend)
VITE_API_BASE_URL=http://e1.chiasegpu.vn:25232

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=

# Enable API debug logging in browser console (true/false)
VITE_API_DEBUG=false
