# Initial VPS config for Docker Compose deployment.
# Copy this file to `.env` on the server and replace placeholder values.

# App
SERVER_PORT=8081
BACKEND_PUBLIC_PORT=25232
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://lihebarbershop.netlify.app
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes

# OAuth
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/haircut_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-this-postgres-password
POSTGRES_DB=haircut_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password

# VietQR
VIETQR_BANK_ID=970422
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=CUTIE CUTS SALON
PAYMENT_WEBHOOK_SECRET=
PAYMENT_EXPIRY_CHECK_DELAY_MS=60000

# Storage / MinIO
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://e1.chiasegpu.vn:53039
S3_UPLOAD_URL=http://e1.chiasegpu.vn:53039
MINIO_PUBLIC_PORT=53039
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-this-minio-secret
S3_BUCKET_AVATARS=avatars
S3_BUCKET_GALLERY=gallery
S3_BUCKET_BARBERS=barbers
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-secret

# Email
APP_MAIL_PROVIDER=console
MAIL_FROM=Cutie Cuts <noreply@example.com>
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Security / Caching
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_OTP_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
ADMIN_DASHBOARD_CACHE_TTL_SECONDS=60
APP_CACHE_CLEANUP_INTERVAL_MS=300000
